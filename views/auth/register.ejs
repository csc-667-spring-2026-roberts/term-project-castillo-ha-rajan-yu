<%- include("../partials/layout-start", { title, user: null }) %>

<%# Registration form for creating a new account. %>
<h1>Create Your Account</h1>
<p>Register to continue to your game lobby.</p>

<%# Server-side validation and conflict errors are rendered here. %>
<% if (error) { %>
<div class="error"><%= error %></div>
<% } %>

<%# Form posts to /auth/register and uses PRG redirect on success. %>
<form method="post" action="/auth/register">
  <label for="username">Username</label>
  <input
    id="username"
    name="username"
    type="text"
    required
    maxlength="50"
    value="<%= formData?.username ?? "" %>"
  />

  <label for="email">Email</label>
  <input
    id="email"
    name="email"
    type="email"
    required
    maxlength="255"
    value="<%= formData?.email ?? "" %>"
  />

  <label for="password">Password</label>
  <input id="password" name="password" type="password" required minlength="8" />

  <button class="button" type="submit">Register</button>
</form>

<div class="meta-row">
  <span>Already have an account?</span>
  <a href="/auth/login">Go to Login</a>
</div>

<%- include("../partials/layout-end") %>
