<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %> | Gator Tycoons</title>
    <link rel="stylesheet" href="/css/styles.css" />
  </head>
  <body>
    <header>
      <nav class="nav">
        <div class="brand">Gator Tycoons</div>
        <div class="nav-actions">
          <% if (typeof user !== "undefined" && user) { %>
          <form action="/auth/logout" method="post">
            <button type="submit">Logout</button>
          </form>
          <% } else { %>
          <a href="/auth/login">Login</a>
          <a href="/auth/register">Register</a>
          <% } %>
        </div>
      </nav>
    </header>
    <main>
      <%# M7: Login page with POST form and inline error display. %>
      <h1>Sign In</h1>
      <p>Enter your credentials to continue.</p>

      <%# Authentication validation errors are rendered here. %>
      <% if (error) { %>
      <div class="error"><%= error %></div>
      <% } %>

      <%# Form posts to /auth/login and redirects on success. %>
      <form method="post" action="/auth/login">
        <label for="email">Email</label>
        <input
          id="email"
          name="email"
          type="email"
          required
          maxlength="255"
          value="<%= formData?.email ?? "" %>"
        />

        <label for="password">Password</label>
        <input id="password" name="password" type="password" required />

        <button class="button" type="submit">Login</button>
      </form>

      <div class="meta-row">
        <span>New here?</span>
        <a href="/auth/register">Create an account</a>
      </div>
    </main>
  </body>
</html>
